# ─── Turso Database (required for Vercel deployment) ─────────────────────────
# Free account at https://turso.tech → create a database → copy the URL + token
# For local dev without Turso, leave these UNSET — falls back to ./mission-control.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Google OAuth (Calendar + Gmail) ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Enable: Google Calendar API, Gmail API
# OAuth 2.0 redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://your-app.vercel.app

# ─── Optional: Claude API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
